{
  "[javascript][javascriptreact][typescript][typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.organizeImports.biome": "always"
    }
  },
  "eslint.validate": [
    "json",
    "markdown",
    "yaml"
  ],
  "biome.linting.enabled": true,
  "biome.javascript.formatter.enabled": true,
  "biome.typescript.formatter.enabled": true,
  "biome.format.enabled": true,
  "editor.formatOnSave": true,
  "cSpell.overrides": [
    {
      "filename": "src/infrastructure/i18n/dictionaries/fr.ts",
      "language": "en,fr"
    }
  ],
  "cSpell.words": [
    "Cantarell",
    "cuid",
    "grayscale",
    "minmax",
    "Neue",
    "nowrap",
    "oklch",
    "pressables",
    "Roboto",
    "Segoe",
    "turbopack"
  ],
  "peacock.color": "#bad4bd",
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#d9e8db",
    "activityBar.background": "#d9e8db",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#a19cc3",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#d9e8db",
    "statusBar.background": "#bad4bd",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#9bc09f",
    "statusBarItem.remoteBackground": "#bad4bd",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#bad4bd",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#bad4bd99",
    "titleBar.inactiveForeground": "#15202b99"
  }
}
