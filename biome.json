{
  "$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useBlockStatements": "error",
        "useConsistentArrayType": "off"
      },
      "suspicious": {
      },
      "complexity": {
        "noUselessTypeConstraint": "error"
      },
      "a11y": {
        "useAnchorContent": "error",
        "noAutofocus": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "none",
      "semicolons": "asNeeded",
      "arrowParentheses": "asNeeded"
    }
  },
  "overrides": [
    {
      "linter": {
        "rules": {
          "style": {
            "useConsistentArrayType": "off"
          }
        }
      }
    }
  ]
}
